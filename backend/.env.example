# ── App ─────────────────────────────────────────────────────────
NODE_ENV=development
PORT=3000
ADMIN_PORT=3002
API_PREFIX=api/v1

# opencode -s ses_0a41a7a60ffeks3nUbLWs07f1K

# ── Database ────────────────────────────────────────────────────
# Option A: Supabase PostgreSQL (recommended)
# Get your connection string from Supabase Dashboard → Project Settings → Database
# DATABASE_URL=postgresql://postgres:[PASSWORD]@db.[REF].supabase.co:5432/postgres

# Option B: Local PostgreSQL (fallback for local dev)
DB_HOST=localhost
DB_PORT=5432
DB_DATABASE=uniform_store
DB_USERNAME=postgres
DB_PASSWORD=postgres
DB_SYNCHRONIZE=false
DB_SSL=false
DB_LOGGING=false

# Enable SSL for database connection (required for Supabase, set to true)
DB_SSL=true
DB_LOGGING=false

# ── Supabase Auth ──────────────────────────────────────────────
SUPABASE_URL=https://[PROJECT_REF].supabase.co
SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ── Admin JWT ──────────────────────────────────────────────────
ADMIN_JWT_SECRET=change-me-in-production
ADMIN_JWT_EXPIRES_IN=8h

# ── Storage (S3-compatible, e.g. Supabase Storage or MinIO) ────
# For Supabase Storage:
# STORAGE_ENDPOINT=https://[PROJECT_REF].supabase.co/storage/v1/s3
# STORAGE_REGION=auto
# STORAGE_ACCESS_KEY=your-s3-access-key
# STORAGE_SECRET_KEY=your-s3-secret-key
# STORAGE_BUCKET=uniform-store
# STORAGE_PUBLIC_URL=https://[PROJECT_REF].supabase.co/storage/v1/object/public/uniform-store
# For MinIO local:
STORAGE_ENDPOINT=http://localhost:9000
STORAGE_REGION=auto
STORAGE_ACCESS_KEY=minioadmin
STORAGE_SECRET_KEY=minioadmin
STORAGE_BUCKET=uniform-store
STORAGE_PUBLIC_URL=http://localhost:9000/uniform-store

# ── CORS ───────────────────────────────────────────────────────
CORS_ORIGINS=http://localhost:3001

# ── Rate Limiting ──────────────────────────────────────────────
THROTTLE_TTL=1000
THROTTLE_LIMIT=100
AUTH_THROTTLE_LIMIT=10
SEARCH_THROTTLE_LIMIT=30
CART_THROTTLE_LIMIT=20

# ── Cache ──────────────────────────────────────────────────────
CACHE_TTL_PRODUCT=300
CACHE_TTL_SEARCH=60
CACHE_TTL_COLLECTION=600
CACHE_TTL_ARTICLE=900

# ── Logging ────────────────────────────────────────────────────
LOG_LEVEL=debug
